############# Functions #######################

mkcd()
{
    case $# in
    1)
        mkdir -p $1
        cd $1
        ;;
    *)
        echo "USAGE: mkcd rep"
        ;;
    esac
}

dockershell()
{
    case $# in
    1)
        docker exec -it $1 bash
        ;;
    *)
        echo "Opens docker shell"
        echo "USAGE: dockershell <docker_container>"
        ;;
    esac
}

dockerrestart()
{
    case $# in
    1)
        cd /home/anirudh/dockerapps/$1
        docker compose down
        docker compose up -d
        cd -
        ;;
    *)
        echo "Restarts docker container"
        echo "USAGE: dockerstart <docker_container>"
        ;;
    esac
}

