# font smoothing
Xft.autohint: 0
Xft.lcdfilter: lcddefault
Xft.hintstyle: hintslight
Xft.hinting: 1
Xft.antialias: 1
Xft.rgba: rgb

# Xterm
XTerm.termName: xterm-256-color
XTerm.vt100.locale: false
XTerm.vt100.utf8: true

XTerm.vt100.foreground: green
XTerm.vt100.background: black
#XTerm.vt100.faceName: DejaVu Sans Mono:style=Book:antialias=false
XTerm.vt100.faceName: Menlo for Powerline:style=Regular:antialias=true
XTerm.vt100.faceSize: 11

